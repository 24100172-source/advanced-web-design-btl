<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<main class="container my-5 py-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="p-4 p-md-5 rounded-4 shadow-lg" style="background-color: #1a1614; border: 1px solid #362e29;">
        
        <div class="text-center mb-4">
          <h3 class="fw-bold text-warning font-serif">Trở Thành Hội Viên</h3>
          <p class="text-white-50 small">Đăng ký ngay để nhận ưu đãi lên đến 15% cho mỗi bữa ăn.</p>
        </div>

        <form action="/auth/register" method="POST" id="booking-form">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label text-white-50 small fw-bold text-uppercase" style="letter-spacing: 1px;">Họ và tên *</label>
              <input type="text" name="fullname" class="form-control py-2 px-3" style="background-color: #241f1c; color: white; border-color: #362e29;" required placeholder="VD: Nguyễn Văn A">
            </div>

            <div class="col-md-6">
              <label class="form-label text-white-50 small fw-bold text-uppercase" style="letter-spacing: 1px;">Số điện thoại *</label>
              <input type="tel" name="phone" class="form-control py-2 px-3" style="background-color: #241f1c; color: white; border-color: #362e29;" required placeholder="0988 xxx xxx">
            </div>

            <div class="col-md-6">
              <label class="form-label text-white-50 small fw-bold text-uppercase" style="letter-spacing: 1px;">Email (Tùy chọn)</label>
              <input type="email" name="email" class="form-control py-2 px-3" style="background-color: #241f1c; color: white; border-color: #362e29;" placeholder="email@example.com">
            </div>
            
            <div class="col-md-6">
              <label class="form-label text-white-50 small fw-bold text-uppercase" style="letter-spacing: 1px;">Mật khẩu *</label>
              <input type="password" name="password" class="form-control py-2 px-3" style="background-color: #241f1c; color: white; border-color: #362e29;" required placeholder="Tối thiểu 6 ký tự">
            </div>

            <div class="col-md-6">
              <label class="form-label text-white-50 small fw-bold text-uppercase" style="letter-spacing: 1px;">Nhập lại Mật khẩu *</label>
              <input type="password" name="confirm_password" class="form-control py-2 px-3" style="background-color: #241f1c; color: white; border-color: #362e29;" required placeholder="Xác nhận mật khẩu">
            </div>

            <div class="col-12 mt-4">
              <button type="submit" class="btn btn-danger w-100 fw-bold rounded-pill py-2 text-white text-uppercase shadow-sm" style="transition: 0.3s; background-color: #ff4a5a; border: none;">
                Đăng Ký Tài Khoản
              </button>
            </div>
          </div>
        </form>

        <div class="text-center mt-4 border-top border-secondary pt-3">
          <p class="text-white-50 small mb-0">Đã có tài khoản? <a href="/auth/login" class="text-warning fw-bold text-decoration-none">Đăng nhập</a></p>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>