<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="container my-5" style="min-height: 60vh;">
  <h2 class="fw-bold mb-4 font-serif text-white">Giỏ Hàng Của Bạn</h2>
  
  <div class="table-responsive">
    <table class="table table-dark table-hover align-middle">
      <thead>
        <tr>
          <th>Món ăn</th>
          <th>Đơn giá</th>
          <th>Số lượng</th>
          <th>Thành tiền</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody id="cart-items">
        <% if (locals.cartItems && cartItems.length > 0) { %>
          <% cartItems.forEach(item => { %>
            <tr id="row-<%= item.id %>" class="cart-row">
              <td>
                <div class="d-flex align-items-center">
                  <img src="/<%= item.image %>" alt="<%= item.name %>" style="width: 60px; height: 60px; object-fit: cover;" class="rounded me-3 border border-secondary" onerror="this.src='/images/default-food.jpg'">
                  <span class="fw-bold text-white"><%= item.name %></span>
                </div>
              </td>
              <td class="text-white-50"><%= item.price.toLocaleString('vi-VN') %>đ</td>
              <td>
                <div class="d-flex align-items-center input-group" style="width: 120px;">
                  <button class="btn btn-sm btn-outline-secondary text-white px-2" onclick="updateQuantity('<%= item.id %>', -1)">-</button>
                  <span id="qty-<%= item.id %>" class="mx-3 text-white fw-bold quantity-val"><%= item.quantity %></span>
                  <button class="btn btn-sm btn-outline-secondary text-white px-2" onclick="updateQuantity('<%= item.id %>', 1)">+</button>
                </div>
              </td>
              <td id="total-<%= item.id %>" class="text-warning fw-bold"><%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ</td>
              <td>
                <button class="btn btn-link text-danger p-0 border-0" onclick="removeItem('<%= item.id %>')">
                  <i class="bi bi-trash fs-5"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="text-center py-5 text-white-50">
              <i class="bi bi-cart-x fs-1 d-block mb-3 text-secondary"></i>
              Giỏ hàng đang trống. <a href="/thuc-don" class="text-warning text-decoration-none fw-bold">Quay lại thực đơn ngay!</a>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-4 p-4 bg-dark rounded-4 border border-secondary">
    <h4 class="text-white mb-0">Tổng cộng: <span id="cart-total" class="text-warning"><%= locals.totalAmount ? totalAmount.toLocaleString('vi-VN') : 0 %></span>đ</h4>
    <a href="/thanh-toan" class="btn btn-warning px-4 py-2 fw-bold rounded-pill hover-scale text-decoration-none text-dark">Tiến hành thanh toán</a>  </div>
</main>

<%- include('partials/footer') %>

<script>
// Hàm tăng / giảm số lượng món bằng Fetch API
async function updateQuantity(productId, change) {
  try {
    const response = await fetch('/cart/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId, change })
    });
    
    const data = await response.json();
    
    if (data.success) {
      if (data.newQuantity === 0) {
        document.getElementById(`row-${productId}`).remove();
        if (document.querySelectorAll('.cart-row').length === 0) {
          location.reload();
        }
      } else {
        document.getElementById(`qty-${productId}`).innerText = data.newQuantity;
        document.getElementById(`total-${productId}`).innerText = data.newItemTotal.toLocaleString('vi-VN') + 'đ';
      }
      
      document.getElementById('cart-total').innerText = data.newCartTotal.toLocaleString('vi-VN');
      
      const badge = document.getElementById('cart-badge');
      if (badge) badge.innerText = data.cartCount;
    }
  } catch (error) {
    console.error('Lỗi khi cập nhật số lượng:', error);
  }
}

// Hàm xóa hoàn toàn món ăn bằng Fetch API
async function removeItem(productId) {
  if (!confirm('Bạn có chắc chắn muốn xóa món ăn này khỏi giỏ hàng?')) return;
  
  try {
    const response = await fetch('/cart/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId })
    });
    
    const data = await response.json();
    
    if (data.success) {
      document.getElementById(`row-${productId}`).remove();
      
      if (document.querySelectorAll('.cart-row').length === 0) {
        location.reload();
      }
      
      document.getElementById('cart-total').innerText = data.newCartTotal.toLocaleString('vi-VN');
      
      const badge = document.getElementById('cart-badge');
      if (badge) badge.innerText = data.cartCount;
    }
  } catch (error) {
    console.error('Lỗi khi xóa món ăn:', error);
  }
}

function checkout() {
  alert("Tính năng đặt món và thanh toán đang được xử lý!");
}
</script>

<style>
body { font-family: 'Plus Jakarta Sans', sans-serif; }
.font-serif { font-family: 'Playfair Display', Georgia, serif; font-style: italic; }
.hover-scale { transition: all 0.3s ease; }
.hover-scale:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(255, 193, 7, 0.3); }
.input-group .btn-outline-secondary { border-color: #495057; color: #ffffff; }
.input-group .btn-outline-secondary:hover { background-color: #ff4a5a; border-color: #ff4a5a; }
.quantity-val { min-width: 30px; text-align: center; display: inline-block; }
.btn-link.text-danger:hover { transform: scale(1.2); }
</style>
