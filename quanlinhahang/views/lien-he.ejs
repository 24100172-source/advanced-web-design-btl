<link rel="stylesheet" href="/css/lien-he.css">

<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="container my-5 py-4">
  
  <div class="text-center mb-5">
    <h5 class="text-warning tracking-wider text-uppercase small" style="letter-spacing: 2px;">Grill House</h5>
    <h1 class="fw-black display-4 mb-3 font-serif text-dark-theme">Liên Hệ Với Chúng Tôi</h1>
    <p class="text-secondary mx-auto" style="max-width: 600px;">
      Chúng tôi luôn sẵn sàng lắng nghe và phục vụ bạn. Hãy để lại tin nhắn hoặc ghé thăm nhà hàng trực tiếp.
    </p>
  </div>

  <div class="row g-5">
    
    <div class="col-lg-5 d-flex flex-column gap-4">
      
      <div class="contact-card p-4 rounded-4 shadow-lg">
        <h4 class="text-white fw-bold mb-4 font-serif">Thông Tin Liên Hệ</h4>
        
        <div class="d-flex align-items-start mb-4">
          <div class="icon-box me-3 mt-1">
            <i class="bi bi-geo-alt-fill text-warning"></i>
          </div>
          <div>
            <h6 class="text-white fw-bold mb-1">Trụ sở chính</h6>
            <p class="text-white-50 small mb-0">168 Trần Thái Tông, Dịch Vọng Hậu, Cầu Giấy, Hà Nội</p>
          </div>
        </div>
        
        <div class="d-flex align-items-start mb-4">
          <div class="icon-box me-3 mt-1">
            <i class="bi bi-telephone-fill text-warning"></i>
          </div>
          <div>
            <h6 class="text-white fw-bold mb-1">Hotline đặt bàn</h6>
            <p class="text-white-50 small mb-0">0988 655 622 (Từ 9:00 - 23:00)</p>
          </div>
        </div>
        
        <div class="d-flex align-items-start">
          <div class="icon-box me-3 mt-1">
            <i class="bi bi-envelope-fill text-warning"></i>
          </div>
          <div>
            <h6 class="text-white fw-bold mb-1">Email hỗ trợ</h6>
            <p class="text-white-50 small mb-0">contact@grillhouse.com.vn</p>
          </div>
        </div>
      </div>

      <div class="contact-card p-2 rounded-4 shadow-lg overflow-hidden h-100 min-h-300">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3723.864753177651!2d105.78857411540237!3d21.03810109283344!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab3696f01193%3A0xc62d228f4955743b!2zMTY4IFRy4bqnbiBUaMOhaSBUw7RuZywgROG1i2NoIFbhu41uZyBI4bqtdSwgQ-G6p3UgR2nhuqV5LCBIw6AgTuG7mWksIFZp4buHdCBOYW0!5e0!3m2!1svi!2s!4v1680000000000!5m2!1svi!2s" 
                width="100%" height="100%" style="border:0; border-radius: 12px; min-height: 250px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>

    <div class="col-lg-7">
      <div class="contact-card p-4 p-md-5 rounded-4 shadow-lg h-100">
        <h4 class="text-white fw-bold mb-4 font-serif">Gửi Tin Nhắn Cho Chúng Tôi</h4>
        
        <form action="/lien-he" method="POST">
          <div class="row g-4">
            
            <div class="col-md-6">
              <label class="form-label text-white-50 small text-uppercase fw-bold tracking-wide">Họ và tên *</label>
              <input type="text" name="name" class="form-control dark-input" required placeholder="Nhập tên của bạn">
            </div>
            
            <div class="col-md-6">
              <label class="form-label text-white-50 small text-uppercase fw-bold tracking-wide">Số điện thoại *</label>
              <input type="tel" name="phone" class="form-control dark-input" required placeholder="0988xxxxxx">
            </div>
            
            <div class="col-12">
              <label class="form-label text-white-50 small text-uppercase fw-bold tracking-wide">Tiêu đề</label>
              <input type="text" name="subject" class="form-control dark-input" placeholder="Ví dụ: Phản hồi dịch vụ, Hợp tác, v.v.">
            </div>
            
            <div class="col-12">
              <label class="form-label text-white-50 small text-uppercase fw-bold tracking-wide">Nội dung tin nhắn *</label>
              <textarea name="message" class="form-control dark-input" rows="5" required placeholder="Bạn muốn nhắn nhủ điều gì với Grill House?"></textarea>
            </div>
            
            <div class="col-12 mt-4">
              <button type="submit" class="btn btn-order w-100 text-center d-block border-0 shadow">
                <i class="bi bi-send-fill me-2"></i> Gửi Tin Nhắn
              </button>
            </div>
            
          </div>
        </form>
      </div>
    </div>

  </div>
</main>

<!-- ================= CONG DONG ĐÁNH GIÁ & PHẢN HỒI ================= -->
<section class="container my-5 py-4">
    <div class="text-center mb-5">
        <h6 class="text-warning text-uppercase mb-2 tracking-wider fw-bold" style="letter-spacing: 2px;">Khách Hàng Nói Gì</h6>
        <!-- SỬA LỖI: Đổi text-white thành text-dark (màu tối) để hiện rõ trên nền sáng -->
        <h2 class="fw-bold text-dark font-serif fs-2">Ý Kiến & Đánh Giá Gần Đây</h2>
        <div class="mx-auto mt-3 bg-warning" style="height: 3px; width: 60px;"></div>
    </div>

    <div class="row g-4">
        <% if (typeof reviews !== 'undefined' && reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
                <div class="col-md-6 col-lg-4">
                    <!-- SỬA LỖI: Card dùng nền tối nhẹ #181310 rất sang, nổi bật hẳn trên nền sáng của trang -->
                    <div class="card h-100 p-4 border-0 rounded-4 transition-all" 
                         style="background: #181310; border: 1px solid #362e29 !important; box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
                        
                        <!-- Header Card: Icon & Tên khách hàng -->
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle bg-warning text-dark d-flex align-items-center justify-content-center fw-bold fs-5" 
                                 style="width: 45px; height: 45px;">
                                <%= review.fullname.charAt(0).toUpperCase() %>
                            </div>
                            <div class="ms-3">
                                <h6 class="text-white mb-0 fw-bold"><%= review.fullname %></h6>
                                <span class="text-warning small">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                        </div>

                        <!-- Tiêu đề phản hồi (nếu có) -->
                        <% if (review.subject) { %>
                            <h6 class="text-warning font-serif mb-2" style="font-style: italic;">
                                "<%= review.subject %>"
                            </h6>
                        <% } %>

                        <!-- Nội dung phản hồi -->
                        <p class="text-white-50 small mb-0 flex-grow-1" style="line-height: 1.6; white-space: pre-wrap;">
                            <%= review.message %>
                        </p>

                        <!-- Ngày gửi -->
                        <div class="mt-3 pt-2 border-top border-secondary text-white-50 small text-end" style="border-color: #362e29 !important; font-size: 0.75rem;">
                            <i class="bi bi-calendar3 me-1"></i>
                            <%= review.created_at ? new Date(review.created_at).toLocaleDateString('vi-VN') : 'Vừa xong' %>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <!-- SỬA LỖI: Đổi text-white-50 thành text-muted (màu tối nhẹ) để nhìn thấy chữ trên nền sáng -->
                <p class="text-muted fs-5 font-serif mb-0">Hãy là người đầu tiên gửi những đánh giá yêu thương đến Grill House!</p>
            </div>
        <% } %>
    </div>
</section>

<style>
    /* Hiệu ứng di chuột cho thẻ đánh giá */
    .transition-all {
        transition: all 0.3s ease-in-out;
    }
    .transition-all:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(255, 193, 7, 0.2) !important;
        border-color: #ffc107 !important;
    }
</style>

<%- include('partials/footer') %>