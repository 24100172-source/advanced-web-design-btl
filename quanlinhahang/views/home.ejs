<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="container my-4">
  
  <section class="hero-section row g-0 mb-5 shadow-lg rounded-4 overflow-hidden" style="background-color: #0f1014;">
    
    <div class="col-md-5 p-5 d-flex flex-column"> 
      
      <div class="mt-4">
        <h6 class="text-warning text-uppercase mb-3 tracking-wider" style="letter-spacing: 2px;">Nhà Hàng Grill House</h6>
        <h1 class="fw-black display-4 mb-3 text-white lh-sm" style="font-weight: 800;">COMBO<br>THỊT NƯỚNG<br>& LẨU</h1>
        <p class="small text-secondary" style="line-height: 1.8;">Thưởng thức hương vị Hàn Quốc đích thực với Combo Thịt Nướng và Lẩu đặc biệt độc quyền tại nhà hàng chúng tôi.</p>
      </div>
      
      <div class="mt-4 mb-4 d-flex flex-column gap-3">
        <div class="d-flex align-items-center text-white-50">
          <i class="bi bi-check-circle-fill text-warning me-3 fs-5"></i>
          <span class="small">100% Thịt bò Wagyu & USDA thượng hạng</span>
        </div>
        <div class="d-flex align-items-center text-white-50">
          <i class="bi bi-check-circle-fill text-warning me-3 fs-5"></i>
          <span class="small">Hơn 15 loại Panchan (đồ ăn kèm) làm mới mỗi ngày</span>
        </div>
        <div class="d-flex align-items-center text-white-50">
          <i class="bi bi-check-circle-fill text-warning me-3 fs-5"></i>
          <span class="small">Không gian riêng tư, hệ thống hút mùi hiện đại</span>
        </div>
      </div>
      
      <div class="mt-auto">
        <div class="mb-4 pt-4">
          <a href="/dat-ban" class="btn btn-light rounded-pill px-4 py-2 fw-bold text-dark btn-order">ĐẶT BÀN NGAY</a>
        </div>
        
        <div class="pt-4 border-top border-secondary row text-secondary small align-items-center">
          <div class="col-6"><i class="bi bi-telephone me-2"></i>+84 988 655 622</div>
          <div class="col-6 text-end"><i class="bi bi-envelope me-2"></i>contact@grillhouse.vn</div>
        </div>
      </div>
      
    </div> <div class="col-md-7 p-3 p-md-4">
      <div class="row g-3 h-100">
        <div class="col-6"><img src="/images/hero-1.jpg" class="img-fluid rounded-3 w-100 h-100 object-fit-cover hero-img-box" alt="food"></div>
        <div class="col-6"><img src="/images/hero-2.jpg" class="img-fluid rounded-3 w-100 h-100 object-fit-cover hero-img-box" alt="food"></div>
        <div class="col-6"><img src="/images/hero-3.jpg" class="img-fluid rounded-3 w-100 h-100 object-fit-cover hero-img-box" alt="food"></div>
        <div class="col-6"><img src="/images/hero-4.jpg" class="img-fluid rounded-3 w-100 h-100 object-fit-cover hero-img-box" alt="food"></div>
      </div>
    </div>
    
  </section>

  <section class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="h-100 rounded-4 overflow-hidden shadow-lg position-relative border" style="border-color: #2a2c35 !important; min-height: 480px;">
        <img src="/images/promo-menu.jpg" class="position-absolute top-0 start-0 img-fluid w-100 h-100 object-fit-cover" alt="Promo Banner">
        
        <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.95), transparent);">
          <span class="badge bg-warning text-dark mb-2 px-3 py-2 rounded-pill fw-bold">MENU MỚI 2024</span>
          <h2 class="text-white fw-bold mb-1">Trải nghiệm BBQ chuẩn Hàn</h2>
          <p class="text-white-50 mb-0">Không gian riêng tư, đẳng cấp cùng thịt bò Wagyu thượng hạng.</p>
        </div>
      </div>
    </div>

    <div class="col-md-6 d-flex flex-column gap-3">
      
      <div class="p-4 p-lg-5 shadow-lg rounded-4 flex-grow-1 d-flex flex-column justify-content-center" style="background: linear-gradient(135deg, #7a1212 0%, #4a0808 100%); border: 1px solid #8c1a1a;">
        <div class="text-center mb-4">
          <h4 class="text-warning fw-bold tracking-wide mb-2" style="letter-spacing: 1.5px;">ƯU ĐÃI ĐẶC BIỆT</h4>
          <span class="text-uppercase small text-white-50 d-block mb-1">Giảm giá lên đến</span>
          <h1 class="display-4 fw-bold my-2 text-white" style="text-shadow: 0 4px 15px rgba(0,0,0,0.5);">500.000đ</h1>
          <span class="small px-4 py-2 rounded-pill mt-2 d-inline-block" style="background-color: rgba(255, 255, 255, 0.1); color: #f8f9fa; border: 1px solid rgba(255,255,255,0.2);">Cho hóa đơn từ 1.590.000đ</span>
        </div>

        <div class="row g-3 mt-auto">
          <div class="col-6">
            <div class="p-3 rounded-3 text-center" style="background-color: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255,193,7, 0.4);">
              <small class="d-block text-warning mb-1">GIẢM GIÁ</small>
              <strong class="text-white fs-5 d-block">50.000đ</strong> 
              <span class="small d-block text-white-50 mt-1">HĐ từ 490k</span>
            </div>
          </div>
          <div class="col-6">
            <div class="p-3 rounded-3 text-center" style="background-color: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255,193,7, 0.4);">
              <small class="d-block text-warning mb-1">GIẢM GIÁ</small>
              <strong class="text-white fs-5 d-block">100.000đ</strong> 
              <span class="small d-block text-white-50 mt-1">HĐ từ 690k</span>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-4 p-4 d-flex align-items-center justify-content-between shadow-lg" style="background: linear-gradient(145deg, #2c2f38 0%, #1e2026 100%); border: 1px solid #3f424f;">
        <div>
          <small class="text-warning fw-bold text-uppercase mb-1 d-block" style="letter-spacing: 1px;">Thịt Nướng Đỉnh Cao</small>
          <h5 class="fw-bold mb-0 text-white lh-base">GIẢM 2% KHI ĐẶT BÀN ONLINE</h5>
        </div>
        <a href="/dat-ban" class="btn btn-warning fw-bold text-dark rounded-pill px-4 flex-shrink-0 border-0 shadow">Đặt bàn ngay</a>
      </div>

    </div>
  </section>

  <section class="best-seller-section rounded-4 shadow-lg mb-5 pb-5 pt-4 px-3 best-seller-bg">
    
    <div class="text-center mb-5 mt-3">
      <h2 class="fw-bold text-warning font-serif fs-1">✨ Best Seller ✨</h2>
    </div>
    
    <div class="row px-lg-3">
      
      <div class="col-md-3 mb-4 mb-md-0">
        <div class="p-3 rounded-4 shadow-sm h-100 dark-sidebar">
          <div class="bg-warning text-dark p-2 text-center rounded-3 mb-3 fw-bold text-uppercase small tracking-wide">Danh Mục Menu</div>
          
          <div class="list-group sidebar-menu-list custom-scrollbar border-0 gap-2">
            <% if(categories && categories.length > 0) { %>
              <% categories.forEach((category) => { %>
                <a href="/thuc-don?category=<%= category.slug %>" class="list-group-item list-group-item-action border-0 rounded-3 px-3 py-2 dark-menu-item" style="transition: 0.3s;">
                  <%= category.name %>
                </a>
              <% }) %>
            <% } else { %>
              <p class="small text-white-50 p-2 text-center">Không tìm thấy danh mục.</p>
            <% } %>
          </div>
        </div>
      </div>
      
      <div class="col-md-9">
        <div class="row row-cols-1 row-cols-md-3 g-4 pb-4">
          <% if(bestSellers && bestSellers.length > 0) { %>
            <% bestSellers.forEach(product => { %>
              
              <div class="col mb-4">
                <div class="card dark-food-card p-3 h-100 d-flex flex-column justify-content-between align-items-center rounded-4 shadow-sm">
                  
                  <div class="position-relative w-100 d-flex justify-content-center food-img-wrapper">
                    <img src="/<%= product.image_url %>" alt="<%= product.name %>" class="rounded-circle object-fit-cover shadow-lg border border-4" style="width: 130px; height: 130px;" onerror="this.src='/images/default-food.jpg'">
                  </div>
                  
                  <div class="card-body p-0 mt-3 text-center w-100">
                    <h6 class="card-title fw-bold text-white px-2 lh-base" style="min-height: 40px;"><%= product.name %></h6>
                  </div>
                  
                  <div class="w-100 d-flex justify-content-between align-items-center mt-3 px-2">
                    <span class="fw-bold text-warning fs-5">
                      <%= product.price.toLocaleString('vi-VN') %>đ
                    </span>
                    <button class="btn btn-danger rounded-circle p-0 d-flex align-items-center justify-content-center shadow border-0 add-to-cart-btn" 
                            style="width: 38px; height: 38px;" 
                            data-id="<%= product._id || product.id %>"
                            data-name="<%= product.name %>"
                            title="Thêm vào giỏ hàng">
                      <i class="bi bi-plus-lg text-white"></i>
                    </button>
                  </div>
                  
                </div>
              </div>
              
            <% }) %>
          <% } else { %>
            <div class="col-12 text-center py-5">
              <p class="text-white-50 fs-5">Chưa có món ăn nổi bật được thiết lập!</p>
            </div>
          <% } %>
        </div>
      </div>
      
    </div>
  </section>

</main>

<%- include('partials/footer') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const addToCartButtons = document.querySelectorAll('.add-to-cart-btn');

    addToCartButtons.forEach(button => {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        
        const productId = this.getAttribute('data-id');
        const productName = this.getAttribute('data-name');

        try {
          const response = await fetch('/cart/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId })
          });
          
          const data = await response.json();
          
          if (data.success) {
            const badge = document.getElementById('cart-badge');
            if (badge) badge.innerText = data.cartCount;
            
            alert(`Đã thêm món "${productName}" vào giỏ hàng thành công!`);
          } else {
            alert('Không thể thêm món ăn: ' + data.message);
          }
        } catch (error) {
          console.error('Lỗi kết nối hệ thống giỏ hàng:', error);
        }
      });
    });
  });
</script>
