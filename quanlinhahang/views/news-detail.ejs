<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="container my-5 py-3">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-11">
            
            <!-- Nút quay lại tinh tế nằm phía trên -->
            <div class="mb-4">
                <a href="/tin-tuc" class="text-warning text-decoration-none fw-bold small hover-white d-inline-flex align-items-center transition-all">
                    <i class="bi bi-arrow-left me-2"></i> Quay lại tin tức
                </a>
            </div>

            <article class="news-detail-section rounded-4 shadow-lg p-4 p-md-5 dark-section-bg text-light" 
                     style="background: #181310; border: 1px solid #362e29;">
                
                <!-- Tag và Ngày tháng -->
                <div class="d-flex align-items-center gap-3 mb-4">
                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold small text-uppercase shadow-sm" style="letter-spacing: 1px;">
                        <%= post.tag || 'Tin tức' %>
                    </span>
                    <span class="text-white-50 small d-flex align-items-center">
                        <i class="bi bi-calendar3 me-2 text-warning"></i>
                        <%= post.created_at ? new Date(post.created_at).toLocaleDateString('vi-VN') : '28/06/2026' %>
                    </span>
                </div>

                <!-- Tiêu đề lớn sang trọng -->
                <h1 class="fw-bold text-white font-serif mb-4 lh-base" style="font-size: 2.5rem; letter-spacing: -0.5px;">
                    <%= post.title %>
                </h1>

                <!-- Tóm tắt bài viết (Summary) -->
                <% if (post.summary) { %>
                    <p class="lead text-white-50 mb-4 pb-4 border-bottom" style="line-height: 1.8; font-style: italic; border-color: #362e29 !important;">
                        <%= post.summary %>
                    </p>
                <% } %>

                <!-- Ảnh bài viết sắc nét (Đã sửa lỗi thiếu dấu < ở đây) -->
                <div class="position-relative w-100 overflow-hidden rounded-4 shadow mb-5" style="max-height: 480px;">
                    <% 
                        // Tạo một biến chứa ảnh mặc định dựa theo ID bài viết
                        let defaultImage = '/images/bo.jpg';
                        if (post.id == 1) {
                            defaultImage = '/images/chi-nhanh-moi.jpg';
                        } else if (post.id == 2) {
                            defaultImage = '/images/menu-moi.jpg';
                        } else if (post.id == 3) {
                            defaultImage = '/images/nuong-bo-wagyu.jpg';
                        }
                    %>
                    <img src="<%= post.image_url ? post.image_url : defaultImage %>" 
                         class="w-100 h-100 object-fit-cover" 
                         alt="<%= post.title %>" 
                         style="max-height: 480px;"
                         onerror="this.onerror=null; this.src='<%= defaultImage %>';">
                </div>

                <!-- Nội dung chi tiết bài viết phong cách tối giản -->
                <div class="post-detail-content lh-lg text-white-50 fs-6" style="letter-spacing: 0.3px;">
                    <%- post.content %>
                </div>

                <!-- Footer của bài viết: Nút kết thúc -->
                <div class="text-center mt-5 pt-4 border-top" style="border-color: #362e29 !important;">
                    <a href="/tin-tuc" class="btn btn-outline-warning px-5 py-2.5 rounded-pill fw-bold text-uppercase transition-all text-decoration-none d-inline-flex align-items-center gap-2"
                       style="border-width: 2px; font-size: 0.85rem; letter-spacing: 1px;">
                        <i class="bi bi-arrow-left-circle"></i> Quay lại danh sách
                    </a>
                </div>

            </article>

        </div>
    </div>
</main>

<%- include('partials/footer') %>

<style>
    /* CSS Tinh tế cho trang chi tiết */
    .dark-section-bg {
        background-color: #181310 !important;
    }
    .hover-white:hover {
        color: #ffffff !important;
    }
    .transition-all {
        transition: all 0.25s ease-in-out;
    }
    .post-detail-content p {
        margin-bottom: 1.5rem;
    }
    .post-detail-content ul, .post-detail-content ol {
        padding-left: 1.5rem;
        margin-bottom: 1.5rem;
        color: #e0e0e0;
    }
    .post-detail-content li {
        margin-bottom: 0.5rem;
    }
    .btn-outline-warning:hover {
        background-color: #ffc107 !important;
        color: #181310 !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 193, 7, 0.25);
    }
</style>